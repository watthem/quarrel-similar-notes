{
  "name": "quarrel-similar-notes",
  "version": "2026.2.27",
  "description": "Find semantically similar notes using local TF-IDF. No API keys, no external calls.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "release": "npm run build && node scripts/release.mjs",
    "release:version": "node scripts/release-version.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "similarity",
    "tfidf",
    "related-notes"
  ],
  "author": "watthem",
  "license": "MIT",
  "dependencies": {
    "@watthem/quarrel": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "vitest": "^1.6.0"
  }
}
